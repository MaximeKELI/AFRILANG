// experimental catalog — IDE signatures only (not core runtime)
module mlentropy

function entropy(probs list number) returns number
end

function normalizeProbs(v list number) returns list number
end

function entropyBits(probs list number) returns number
end

function maxEntropy(n number) returns number
end

function crossEntropy(p list number, q list number) returns number
end

function perplexity(probs list number) returns number
end

end
