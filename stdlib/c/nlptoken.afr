// experimental catalog — IDE signatures only (not core runtime)
module nlptoken

function tokenize(s text) returns list text
end

function tokenCount(s text) returns number
end

function uniqueTokens(s text) returns list text
end

function joinTokens(parts list text, delim text) returns text
end

function hasToken(s text, term text) returns bool
end

function tokenAt(s text, index number) returns text
end

end
