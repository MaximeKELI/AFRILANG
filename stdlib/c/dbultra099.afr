end

function maxColumn(path text, table text, col text) returns number
end

function updateWhere(path text, table text, setClause text, whereClause text) returns bool
end

function clearTable(path text, table text) returns bool
end

function selectTop(path text, table text, limit number) returns text
end

function countLines(text text) returns number
end

function sumColumn(path text, table text, col text) returns number
end

