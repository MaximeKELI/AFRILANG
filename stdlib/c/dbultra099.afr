// experimental catalog — IDE signatures only (not core runtime)
module dbultra099

function execSql(path text, sql text) returns bool
end

function queryRows(path text, sql text) returns text
end

function selectAll(path text, table text) returns text
end

function insertRow(path text, table text, columns text, values text) returns number
end

