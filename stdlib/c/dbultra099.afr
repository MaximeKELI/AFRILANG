end

function rowCount(path text, table text) returns number
end

function tableExists(path text, table text) returns bool
end

function dropTable(path text, table text) returns bool
end

function createTable(path text, ddl text) returns bool
end

function listTables(path text) returns text
end

function escapeLiteral(value text) returns text
end

function scalarQuery(path text, sql text) returns number
end

function writeQueryCsv(outPath text, dbPath text, sql text) returns bool
end

