// experimental catalog — IDE signatures only (not core runtime)
module mlnormalize

function l2Normalize(v list number) returns list number
end

function minMaxNormalize(v list number) returns list number
end

function zScore(v list number) returns list number
end

function l1Normalize(v list number) returns list number
end

function clip(v list number, lo number, hi number) returns list number
end

end
