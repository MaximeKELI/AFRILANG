// experimental catalog — IDE signatures only (not core runtime)
module mldistance

function euclidean(a list number, b list number) returns number
end

function manhattan(a list number, b list number) returns number
end

function chebyshev(a list number, b list number) returns number
end

function squaredEuclidean(a list number, b list number) returns number
end

function hamming(a list number, b list number) returns number
end

end
