class Counter
    public field n number

    function init()
        set this.n = 0
    end

    function inc() returns number
        set this.n = this.n + 1
        return this.n
    end
end

class Animal
    function speak() returns text
        return "..."
    end
end

class Dog extends Animal
    function speak() returns text
        return "woof"
    end
end

class Cat extends Animal
    function speak() returns text
        return "meow"
    end
end

test "class method and field"
    create c = new Counter
    assert c.inc() is equal to 1
    assert c.inc() is equal to 2
    assert c.n is equal to 2
end

test "inheritance override"
    create d = new Dog
    assert d.speak() is equal to "woof"
end

test "polymorphic list of animals"
    create pets list of Animal = list of new Dog(), new Cat()
    assert (pets at 0).speak() is equal to "woof"
    assert (pets at 1).speak() is equal to "meow"
end
