generator function counter(n int) returns list int
    create i int = 0
    while i is less than n do
        yield i
        set i = i + 1
    end
end

class Countdown
    public field current number
    function hasNext() returns bool
        return current is greater than 0
    end
    function next() returns number
        set current = current - 1
        return current + 1
    end
end

test "inclusive range"
    create total number = 0
    for each x in 1..5 do
        set total = total + x
    end
    assert total is equal to 15
end

test "exclusive range"
    create total number = 0
    for each x in 1..<5 do
        set total = total + x
    end
    assert total is equal to 10
end

test "range as list value"
    create xs = 1..3
    assert (xs at 0) is equal to 1
    assert (xs at 2) is equal to 3
    assert (length of xs) is equal to 3
end

test "for each over generator"
    create sum number = 0
    for each v in counter(4) do
        set sum = sum + v
    end
    assert sum is equal to 6
end

test "for each over iterator protocol"
    create c = new Countdown()
    set c.current = 3
    create sum number = 0
    for each v in c do
        set sum = sum + v
    end
    assert sum is equal to 6
end
