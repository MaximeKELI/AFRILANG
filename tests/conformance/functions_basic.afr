function greet(name text) returns text
    return "hi " + name
end

test "function call return"
    assert greet("Ada") is equal to "hi Ada"
end

test "nested if"
    create n number = 2
    create label text = ""
    if n is greater than 0 then
        if n is less than 5 then
            set label = "ok"
        end
    end
    assert label is equal to "ok"
end
