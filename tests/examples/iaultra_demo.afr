import "std/c/iaultra001"
use iaultra001

test "iaultra_demo"
    create logits = list of 1, 3, 2
    create probs = softmax(logits)
    assert argmax(probs) is equal to 1
    create features = list of 1, 2, 3
    create weights = list of 0.2, -0.1, 0.5
    assert cosineSim(features, weights) is greater than 0
    create ytrue = list of 1, 0, 1, 1, 0
    create ypred = list of 1, 0, 0, 1, 0
    assert accuracy(ytrue, ypred) is equal to 0.8
end
