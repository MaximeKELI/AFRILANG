import "std/proba"
import "std/math"
import "std/stats"

use proba
use math
use stats

test "factorial comb perm"
    assert factorial(5) is equal to 120
    assert comb(5, 2) is equal to 10
    assert perm(5, 2) is equal to 20
end

test "core distributions"
    assert normalCdf(0, 0, 1) is equal to 0.5
    assert uniformCdf(0.5, 0, 1) is equal to 0.5
    assert geometricPdf(0, 0.5) is equal to 0.5
    assert binomialPdf(0, 1, 0.5) is equal to 0.5
    assert studentTCdf(0, 10) is equal to 0.5
    assert logNormalCdf(1, 0, 1) is equal to 0.5
    assert weibullCdf(0, 1, 1) is equal to 0
    assert paretoCdf(1, 2) is equal to 0
end

test "python random surface"
    seed(42)
    create u = rand(1)
    assert u is greater than (0 - 0.1)
    assert u is less than 1.1
    assert randint(1, 1) is equal to 1
    assert gauss(0, 0) is equal to 0
    create b = betavariate(2, 2)
    assert b is greater than 0
    assert b is less than 1
    create w = weibullvariate(1, 1)
    assert w is greater than (0 - 0.1)
    create bag = list of 10, 20, 30
    create pick = sampleChoice(bag)
    assert pick is greater than 9
    create sh = sampleWithoutReplacement(bag, 2)
    assert count(sh) is equal to 2
end
