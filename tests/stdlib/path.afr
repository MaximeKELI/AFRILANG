import "std/path"
use path

test "path join basename"
    assert join("a", "b") is equal to "a/b"
    assert basename("a/b/c.txt") is equal to "c.txt"
    assert dirname("a/b/c.txt") is equal to "a/b"
    assert extension("a/b/c.txt") is equal to ".txt"
end

test "path absolute normalize"
    assert isAbsolute("/tmp") is equal to true
    assert isAbsolute("tmp") is equal to false
    create abs = absolute(".")
    assert isAbsolute(abs) is equal to true
    create norm = normalize("a/b/../c")
    assert basename(norm) is equal to "c"
end

test "path edges"
    assert basename("file") is equal to "file"
    assert dirname("file") is equal to "."
    assert extension("file") is equal to ""
    assert extension("a.tar.gz") is equal to ".gz"
    assert basename("/tmp/") is equal to "tmp"
    create j = join("/tmp", "x")
    assert isAbsolute(j) is equal to true
    assert basename(j) is equal to "x"
end
