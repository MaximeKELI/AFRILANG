import "std/crypto"

use crypto

test "sha256 abc"
    assert sha256("abc") is equal to "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"
end

test "sha512 and sha1 nonempty"
    create h512 = sha512("abc")
    create h1 = sha1("abc")
    assert h512 is equal to "ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f"
    assert h1 is equal to "a9993e364706816aba3e25717850c26c9cd0d89d"
end

test "hmacSha256"
    assert hmacSha256("key", "The quick brown fox jumps over the lazy dog") is equal to "f7bc83f430538424b13298e6aa6fb143ef4d59a14946175997479dbc2d1a3cd8"
end

test "hex encode decode"
    assert hexEncode("Hi") is equal to "4869"
    assert hexDecode("4869") is equal to "Hi"
end

test "aes gcm roundtrip"
    create key = "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
    create packed = aesGcmEncrypt(key, "secret")
    assert aesGcmDecrypt(key, packed) is equal to "secret"
end

test "randomHex length"
    create r = randomHex(16)
    assert r is equal to hexEncode(hexDecode(r))
end

test "ed25519 sign verify"
    create priv = ed25519GenPrivate()
    create pub = ed25519PublicFromPrivate(priv)
    create sig = ed25519Sign(priv, "hello afrilang")
    assert ed25519Verify(pub, "hello afrilang", sig) is equal to true
    assert ed25519Verify(pub, "tampered", sig) is equal to false
end
