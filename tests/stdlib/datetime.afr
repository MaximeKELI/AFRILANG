import "std/datetime"

use datetime

test "parseIso utc"
    create t = parseIso("1970-01-02T00:00:00Z")
    assert t is equal to 86400
end

test "parseIso with offset"
    create t = parseIso("1970-01-01T02:00:00+02:00")
    assert t is equal to 0
end

test "decomposition"
    create t = parseIso("2024-07-22T13:45:30Z")
    assert year(t) is equal to 2024
    assert month(t) is equal to 7
    assert day(t) is equal to 22
    assert hour(t) is equal to 13
    assert minute(t) is equal to 45
    assert second(t) is equal to 30
end

test "weekday"
    create t = parseIso("2024-07-22T00:00:00Z")
    assert weekday(t) is equal to 1
end

test "arithmetic"
    create t = parseIso("2024-01-01T00:00:00Z")
    assert addDays(t, 1) is equal to (t + 86400)
    assert addSeconds(t, 60) is equal to (t + 60)
end

test "format roundtrip"
    create t = parseIso("2024-07-22T13:45:30Z")
    assert formatIso(t) is equal to "2024-07-22T13:45:30Z"
    assert formatIsoOffset(t, 120) is equal to "2024-07-22T15:45:30+02:00"
end
