interface Speakable
    function speak()
end

interface Named
    function getName() returns text
end

class Animal
    function speak()
        say "..."
    end
end

class Dog extends Animal implements Speakable, Named
    function speak()
        say "Woof!"
    end

    function getName() returns text
        return "Rex"
    end
end

create dog = new Dog
dog.speak()
say dog.getName()
