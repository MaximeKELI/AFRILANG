{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "AFRILANG",
  "scopeName": "source.afrilang",
  "patterns": [
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#strings" },
    { "include": "#numbers" }
  ],
  "repository": {
    "keywords": {
      "patterns": [{
        "name": "keyword.control.afrilang",
        "match": "\\b(class|classe|function|fonction|end|fin|if|si|then|alors|else|sinon|while|tantque|do|faire|for|pour|each|chaque|return|retourner|renvoyer|interface|implements|implemente|test|tester|assert|verifier|error|erreur|create|creer|say|dire|module|use|utiliser|import|importer|export|exporter|record|enregistrement|extends|etend|returns|retourne|repeat|repeter|times|fois|stop|arreter|skip|passer|enum|enumeration|union|case|cas|match|associer|default|defaut|with|avec|defined|defini|nothing|rien|ask|demander|into|en|new|nouveau|public|private|prive|protected|protege|empty|vide|explain|expliquer|is|est|greater|superieur|than|less|inferieur|equal|egal|and|et|or|ou|not|pas|set|definir|this|ceci|add|ajouter|length|longueur|of|de|from|depuis|extern|externe|map|carte|filter|filtrer|reduce|reduire|flatMap|aplatir|where|super|static|statique|abstract|abstrait|final|fini|property|propriete|destroy|detruire|async|asynchrone|await|attendre|task|tache|try|essayer|catch|attraper|raise|lever|const|constante|step|etape|open|ouvrir|window|fenetre|titled|intitule|close|fermer|clear|effacer|background|arriereplan|color|couleur|draw|dessiner|text|texte|button|bouton|clicked|clique|show|afficher|frame|cadre|size|taille|width|largeur|height|hauteur|at|operator|operateur|yes|oui|no|non)\\b"
      }]
    },
    "types": {
      "patterns": [{
        "name": "storage.type.afrilang",
        "match": "\\b(number|text|bool|list)\\b|\\btext\\?"
      }]
    },
    "constants": {
      "patterns": [{
        "name": "constant.language.afrilang",
        "match": "\\b(true|false|yes|no)\\b"
      }]
    },
    "strings": {
      "patterns": [{
        "name": "string.quoted.double.afrilang",
        "begin": "\"", "end": "\"",
        "patterns": [{ "name": "constant.character.escape.afrilang", "match": "\\\\." }]
      }]
    },
    "numbers": {
      "patterns": [{
        "name": "constant.numeric.afrilang",
        "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
      }]
    }
  }
}
