{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "AFRILANG",
  "scopeName": "source.afrilang",
  "patterns": [{ "include": "#keywords" }, { "include": "#strings" }],
  "repository": {
    "keywords": {
      "patterns": [{
        "name": "keyword.control.afrilang",
        "match": "\\b(class|function|end|if|then|else|while|do|for|each|return|interface|implements|test|assert|error|create|say|module|use|import|record|extends|returns|repeat|times|stop|skip)\\b"
      }]
    },
    "strings": {
      "patterns": [{
        "name": "string.quoted.double.afrilang",
        "begin": "\"", "end": "\"",
        "patterns": [{ "name": "constant.character.escape.afrilang", "match": "\\\\." }]
      }]
    }
  }
}
