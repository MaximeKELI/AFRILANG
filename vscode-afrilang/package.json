{
  "name": "afrilang",
  "displayName": "AFRILANG",
  "description": "Langage AFRILANG — coloration, diagnostics, LSP, formatage et exécution (.afr)",
  "version": "1.2.0",
  "publisher": "afrilang",
  "license": "MIT",
  "icon": "icons/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaximeKELI/AFRILANG.git",
    "directory": "vscode-afrilang"
  },
  "bugs": {
    "url": "https://github.com/MaximeKELI/AFRILANG/issues"
  },
  "homepage": "https://github.com/MaximeKELI/AFRILANG#readme",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Programming Languages"],
  "keywords": ["afrilang", "africa", "natural language", "afr", "compiler", "lsp"],
  "main": "./extension.js",
  "activationEvents": ["onLanguage:afrilang", "onStartupFinished", "onDebug"],
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "vscode-languageclient": "^9.0.1"
  },
  "contributes": {
    "languages": [{
      "id": "afrilang",
      "aliases": ["AFRILANG", "afrilang"],
      "extensions": [".afr"],
      "configuration": "./language-configuration.json",
      "icon": {
        "light": "icons/afr-light.png",
        "dark": "icons/afr-dark.png"
      }
    }],
    "iconThemes": [{
      "id": "afrilang-icons",
      "label": "AFRILANG",
      "path": "./icons/afrilang-icon-theme.json"
    }],
    "grammars": [{
      "language": "afrilang",
      "scopeName": "source.afrilang",
      "path": "./syntaxes/afrilang.tmLanguage.json"
    }],
    "configuration": {
      "title": "AFRILANG",
      "properties": {
        "afrilang.serverPath": {
          "type": "string",
          "default": "${workspaceFolder}/build/afrilang",
          "description": "Chemin vers l'exécutable afrilang (absolu ou ${workspaceFolder}/build/afrilang)."
        },
        "afrilang.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace des échanges LSP dans la sortie « AFRILANG LSP »."
        }
      }
    },
    "breakpoints": [
      { "language": "afrilang" }
    ],
    "debuggers": [
      {
        "type": "afrilang",
        "label": "AFRILANG",
        "languages": ["afrilang"],
        "program": "./debugAdapter.js",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Fichier .afr à débugger",
                "default": "${file}"
              },
              "afrilangPath": {
                "type": "string",
                "description": "Chemin vers l'exécutable afrilang",
                "default": "${config:afrilang.serverPath}"
              },
              "cwd": {
                "type": "string",
                "description": "Répertoire de travail",
                "default": "${fileDirname}"
              },
              "args": {
                "type": "array",
                "items": { "type": "string" },
                "default": []
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "AFRILANG: Fichier courant",
            "type": "afrilang",
            "request": "launch",
            "program": "${file}",
            "afrilangPath": "${config:afrilang.serverPath}",
            "cwd": "${fileDirname}"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "afrilang.runFile",
        "title": "AFRILANG: Exécuter le fichier",
        "icon": "$(play)"
      },
      {
        "command": "afrilang.checkFile",
        "title": "AFRILANG: Vérifier le fichier",
        "icon": "$(check)"
      },
      {
        "command": "afrilang.restartServer",
        "title": "AFRILANG: Redémarrer le serveur LSP",
        "icon": "$(refresh)"
      },
      {
        "command": "afrilang.debugFile",
        "title": "AFRILANG: Débugger le fichier",
        "icon": "$(debug-alt)"
      },
      {
        "command": "afrilang.initDebugConfig",
        "title": "AFRILANG: Initialiser la config debug (launch.json)",
        "icon": "$(debug-console)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "when": "resourceLangId == afrilang",
          "command": "afrilang.runFile",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceLangId == afrilang",
          "command": "afrilang.runFile",
          "group": "navigation@1"
        },
        {
          "when": "resourceLangId == afrilang",
          "command": "afrilang.checkFile",
          "group": "navigation@2"
        },
        {
          "when": "resourceLangId == afrilang",
          "command": "afrilang.debugFile",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "afrilang.runFile",
          "when": "resourceLangId == afrilang"
        },
        {
          "command": "afrilang.checkFile",
          "when": "resourceLangId == afrilang"
        },
        {
          "command": "afrilang.restartServer",
          "when": "resourceLangId == afrilang"
        },
        {
          "command": "afrilang.debugFile",
          "when": "resourceLangId == afrilang"
        },
        {
          "command": "afrilang.initDebugConfig",
          "when": "resourceLangId == afrilang"
        }
      ]
    }
  }
}
