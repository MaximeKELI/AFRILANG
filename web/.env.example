DEBUG=1
SECRET_KEY=change-me-in-production-use-django-secret-key-generator
# PostgreSQL (production) — voir docker-compose.yml
# USE_SQLITE=1 pour dev local sans Docker
USE_SQLITE=0
DATABASE_URL=postgres://afrilang:afrilang@127.0.0.1:5434/afrilang

# Chemin vers le compilateur (depuis la racine du repo)
AFRILANG_BIN=../build/afrilang
AFRILANG_ROOT=..
