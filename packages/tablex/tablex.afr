module tablex
    function row(a text, b text) returns text
        return "| " + a + " | " + b + " |"
    end

    function separator(width int) returns text
        create out text = "+"
        create i int = 0
        while i is less than width do
            set out = out + "-"
            set i = i + 1
        end
        return out + "+"
    end

    function header(title text) returns text
        return "# " + title
    end
end
