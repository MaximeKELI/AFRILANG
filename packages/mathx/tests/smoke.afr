import "pkg/mathx/mathx.afr"

use mathx

test "gcd and lcm"
    assert gcd(12, 18) is equal to 6
    assert lcm(4, 6) is equal to 12
end

test "isPrime"
    assert isPrime(7) is equal to true
    assert isPrime(9) is equal to false
    assert isPrime(1) is equal to false
end

test "factorial and clamp"
    assert factorial(5) is equal to 120
    assert clampInt(12, 0, 10) is equal to 10
    assert clampInt(0 - 3, 0, 10) is equal to 0
end
