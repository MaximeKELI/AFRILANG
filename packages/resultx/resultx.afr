module resultx
    // Helpers "orientés Result" sans type Result en paramètre (surface MVP).
    function okValue(n number) returns number
        return n
    end

    function fallback(n number, alt number) returns number
        if n is equal to 0 then
            return alt
        end
        return n
    end

    function mapDouble(n number) returns number
        return n * 2
    end

    function isZero(n number) returns bool
        return n is equal to 0
    end
end
