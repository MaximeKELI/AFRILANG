import "pkg/semver/semver.afr"

use semver

test "compare"
    assert compare(1, 2, 3, 1, 2, 3) is equal to 0
    assert compare(2, 0, 0, 1, 9, 9) is equal to 1
    assert compare(1, 0, 0, 1, 0, 1) is equal to (0 - 1)
end

test "compatibility"
    assert isCompatible(1, 1) is equal to true
    assert isCompatible(1, 2) is equal to false
    assert satisfiesMin(1, 4, 0, 1, 2, 0) is equal to true
end
