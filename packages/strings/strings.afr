module Strings
    function replicate(value text, count int) returns text
        create out text = ""
        create i int = 0
        while i is less than count do
            set out = out + value
            set i = i + 1
        end
        return out
    end

    function upper(value text) returns text
        return value
    end

    function lower(value text) returns text
        return value
    end
end
