import "pkg/llmx/llmx.afr"
use llmx

test "buildChatBody"
    create body = buildChatBody("llama3", "hello")
    assert buildChatBody("llama3", "hello") is equal to "{\"model\":\"llama3\",\"messages\":[{\"role\":\"user\",\"content\":\"hello\"}]}"
end

test "escape quotes in body"
    create body = buildChatBody("m", "say \"hi\"")
    assert body is equal to "{\"model\":\"m\",\"messages\":[{\"role\":\"user\",\"content\":\"say \\\"hi\\\"\"}]}"
end

test "chatUrl"
    assert chatUrl("http://127.0.0.1:11434/v1") is equal to "http://127.0.0.1:11434/v1/chat/completions"
    assert chatUrl("http://127.0.0.1:11434/v1/") is equal to "http://127.0.0.1:11434/v1/chat/completions"
end

test "extractAssistantText"
    create raw = "{\"choices\":[{\"message\":{\"role\":\"assistant\",\"content\":\"Bonjour\"}}]}"
    assert extractAssistantText(raw) is equal to "Bonjour"
    assert extractAssistantText("") is equal to ""
    assert extractAssistantText("{}") is equal to ""
end

test "authHeader"
    assert authHeader("") is equal to ""
    assert authHeader("sk-test") is equal to "Authorization: Bearer sk-test\n"
end
