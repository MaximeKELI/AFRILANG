module strx
    function isEmpty(s text) returns bool
        return s is equal to ""
    end

    function join3(a text, b text, c text) returns text
        return a + b + c
    end

    function repeat(s text, n int) returns text
        create out text = ""
        create i int = 0
        while i is less than n do
            set out = out + s
            set i = i + 1
        end
        return out
    end
end
