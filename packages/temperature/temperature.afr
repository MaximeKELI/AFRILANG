module temperature
    function cToF(c number) returns number
        return c * 9 / 5 + 32
    end

    function fToC(f number) returns number
        return (f - 32) * 5 / 9
    end

    function cToK(c number) returns number
        return c + 273.15
    end

    function kToC(k number) returns number
        return k - 273.15
    end
end
