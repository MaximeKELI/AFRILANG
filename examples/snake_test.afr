import "snake_logic.afr"

import "std/m/random2"
use random2

import "std/stopwatch"
use stopwatch

test "snakeOccupies detects head"
    create xs list number = list of 5, 4, 3
    create ys list number = list of 5, 5, 5
    assert snakeOccupies(xs, ys, 3, 5, 5) is equal to true
end

test "snakeOccupies ignores tail miss"
    create xs list number = list of 5, 4, 3
    create ys list number = list of 5, 5, 5
    assert snakeOccupies(xs, ys, 3, 9, 9) is equal to false
end

test "isWallCell detects borders"
    create w number = 12
    create h number = 10
    assert isWallCell(0, 3, w, h) is equal to true
    assert isWallCell(3, 0, w, h) is equal to true
    assert isWallCell(w - 1, 3, w, h) is equal to true
    assert isWallCell(3, h - 1, w, h) is equal to true
    assert isWallCell(5, 5, w, h) is equal to false
end

test "resetGame creates valid snake"
    create w number = 12
    create h number = 10
    seedRandom(42)
    create xs list number = list of 0, 0, 0
    create ys list number = list of 0, 0, 0
    create pack = resetGame(xs, ys, w, h)
    create len0 number = pack at 0
    create dir0 number = pack at 1
    create diry0 number = pack at 2
    create score0 number = pack at 3
    assert len0 is equal to 3
    assert dir0 is equal to 1
    assert diry0 is equal to 0
    assert score0 is equal to 0
    create foodX number = pack at 4
    create foodY number = pack at 5
    assert snakeOccupies(xs, ys, 3, foodX, foodY) is equal to false
end

test "placeFood avoids snake body"
    create w number = 12
    create h number = 10
    seedRandom(99)
    create xs list number = list of 4, 3, 2
    create ys list number = list of 4, 4, 4
    create food = placeFood(xs, ys, 3, w, h)
    create foodX number = food at 0
    create foodY number = food at 1
    assert foodNotOnSnake(xs, ys, 3, foodX, foodY) is equal to true
end

test "stepSnake moves forward"
    create w number = 12
    create h number = 10
    seedRandom(7)
    create xs list number = list of 5, 4, 3
    create ys list number = list of 5, 5, 5
    create result = stepSnake(xs, ys, 3, 1, 0, 8, 8, 0, w, h)
    create over number = result at 4
    assert over is equal to 0
    create hx number = xs at 0
    create hx1 number = xs at 1
    create hx2 number = xs at 2
    assert hx is equal to 6
    assert hx1 is equal to 5
    assert hx2 is equal to 4
end

test "stepSnake eats food and grows"
    create w number = 12
    create h number = 10
    seedRandom(11)
    create xs list number = list of 4, 3, 2
    create ys list number = list of 4, 4, 4
    create result = stepSnake(xs, ys, 3, 1, 0, 5, 4, 0, w, h)
    create newFx number = result at 2
    create newFy number = result at 3
    create newLen number = result at 0
    create newScore number = result at 1
    create over2 number = result at 4
    assert newLen is equal to 4
    assert newScore is equal to 1
    assert over2 is equal to 0
    assert foodNotOnSnake(xs, ys, 4, newFx, newFy) is equal to true
end

test "stepSnake dies on wall"
    create w number = 12
    create h number = 10
    create xs list number = list of w - 2, w - 3, w - 4
    create ys list number = list of 4, 4, 4
    create result = stepSnake(xs, ys, 3, 1, 0, 1, 1, 0, w, h)
    create over3 number = result at 4
    assert over3 is equal to 1
end

test "stepSnake dies on self"
    create w number = 12
    create h number = 10
    create xs list number = list of 5, 5, 4
    create ys list number = list of 5, 4, 4
    create result = stepSnake(xs, ys, 3, 0, -1, 1, 1, 0, w, h)
    create over4 number = result at 4
    assert over4 is equal to 1
end

test "moveMsForDifficulty scales speed"
    create easy number = moveMsForDifficulty(0, 1)
    create hard number = moveMsForDifficulty(0, 3)
    assert hard is less than easy
end

test "shouldPauseOnSpace blocks same frame"
    assert shouldPauseOnSpace(yes) is equal to false
    assert shouldPauseOnSpace(no) is equal to true
end

test "countdown blocks early movement"
    assert canMoveAfterCountdown(0) is equal to false
    assert canMoveAfterCountdown(500) is equal to false
    assert canMoveAfterCountdown(1500) is equal to true
end

test "countdown labels sequence"
    create l1 text = countdownLabel(100)
    create l2 text = countdownLabel(450)
    create l3 text = countdownLabel(700)
    create l4 text = countdownLabel(1000)
    create l5 text = countdownLabel(2000)
    assert l1 is equal to "3"
    assert l2 is equal to "2"
    assert l3 is equal to "1"
    assert l4 is equal to "GO!"
    assert l5 is equal to ""
end

say "Snake logic tests defined"
