// NLP — levenshtein puis jaccard (fichiers séparés évitent le clash `distance`)
import "std/c/nlplevenshtein"
use nlplevenshtein

create a = "kitten"
create b = "sitting"
create h1 = "hello"
create h2 = "hallo"
create c1 = "couleur"
create c2 = "couleurs"

say "levenshtein kitten/sitting={distance(a, b)}"
say "similarity hello/hallo={similarity(h1, h2)}"
say "isClose couleurs={isClose(c1, c2, 2)}"
say "normalized={normalizedDist(a, b)}"
