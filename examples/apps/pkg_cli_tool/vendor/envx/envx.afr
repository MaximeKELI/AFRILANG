import "std/str"
use str

module envx
    function parseKey(raw text) returns text
        create parts = split(raw, "=")
        if length of parts is less than 1 then
            return ""
        end
        return parts at 0
    end

    function parseValue(raw text) returns text
        create parts = split(raw, "=")
        if length of parts is less than 2 then
            return ""
        end
        return parts at 1
    end

    function format(key text, value text) returns text
        return key + "=" + value
    end
end
