module flagx
    function hasFlag(args list text, flag text) returns bool
        create i int = 0
        while i is less than length of args do
            if (args at i) is equal to flag then
                return true
            end
            set i = i + 1
        end
        return false
    end

    function flagValue(args list text, flag text) returns text
        create i int = 0
        while i is less than length of args do
            if (args at i) is equal to flag then
                create j int = i + 1
                if j is less than length of args then
                    return args at j
                end
                return ""
            end
            set i = i + 1
        end
        return ""
    end
end
