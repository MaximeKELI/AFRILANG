enum Status
    case Ok
    case Error with message text
end

create s = Status.Ok
create e = Status.Error with "failed"

create okLabel = match s
    case Ok then "success"
    end
    default "unknown"
    end
end

create errLabel = match e
    case Error with msg then msg
    end
    default "no error"
    end
end

create code = match s
    case Ok then 0
    end
    case Error with msg then 1
    end
end

say okLabel
say errLabel
say code
