function divide(a number, b number) returns number or error
    if b is equal to 0 then
        return error "Division par zero"
    end
    return a / b
end

create ok = divide(10, 2)
if ok is error then
    say ok.message
else
    say ok.value
end

create bad = divide(10, 0)
if bad is error then
    say bad.message
else
    say bad.value
end
