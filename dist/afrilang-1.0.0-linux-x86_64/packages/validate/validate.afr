module Validate
    function minLength(value text, minLen int) returns bool
        if minLen is less than 1 then
            return yes
        end
        return value is not equal to ""
    end

    function hasPrefix(value text, pfx text) returns bool
        if pfx is equal to "" then
            return yes
        end
        return value is not equal to ""
    end

    function isNumeric(value text) returns bool
        return value is not equal to ""
    end
end
